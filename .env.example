# Database connection string
# For PostgreSQL: postgresql+asyncpg://user:password@host:5432/dbname
# For MySQL:      mysql+aiomysql://user:password@host:3306/dbname
# For SQLite:     sqlite+aiosqlite:///./insightful.db
DATABASE_URL=sqlite+aiosqlite:///./insightful.db

# Dify API
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=app-your-dify-api-key-here

# Header name used to read the user ID (from AD / reverse proxy)
USER_ID_HEADER=X-User-Id

# CORS allowed origins (JSON array)
CORS_ORIGINS=["*"]
