# =============================================================================
# insightful-service — Docker development overrides
# =============================================================================
# Copy this file to .env.docker and fill in secret values.
# docker-compose.yml uses this file via env_file + environment: overrides.
#
# Values here are specifically tuned for running inside Docker Compose
# where service names replace "localhost".
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path is relative to WORKDIR /app inside the container.
# The entire insightful-service directory is bind-mounted to /app, so
# insightful.db persists on your host machine automatically.
DATABASE_URL=sqlite+aiosqlite:///./insightful.db

# ── Dify API ──────────────────────────────────────────────────────────────────
# Inside docker_default network, Dify's nginx service name is "nginx".
# Direct API (without nginx) is "api" on port 5001.
DIFY_BASE_URL=http://nginx/v1
DIFY_API_KEY=app-tx7pe7DBig461pLnNARqPpOa
DIFY_KNOWLEDGE_API_KEY=dataset-aEZyPHFc6cdLRE7KAfsthQU2

# ── Misspell Correction API ───────────────────────────────────────────────────
MISSPELL_API_KEY=app-LyZuDZRKHU8MfTnOMOsozne9
MISSPELL_BASE_URL=http://nginx/v1

# ── Dify PostgreSQL ───────────────────────────────────────────────────────────
# In docker_default network the Postgres service container is "docker-db_postgres-1"
# but is reachable by its Compose service name "db".
POSTGRES_USER=postgres
POSTGRES_PASSWORD=difyai123456
POSTGRES_HOST=db_postgres
POSTGRES_PORT=5432
POSTGRES_DB=dify

# ── Weaviate ──────────────────────────────────────────────────────────────────
# In docker_default network the Weaviate container is "docker-weaviate-1",
# reachable by service name "weaviate".
# Internal HTTP port is 8080 (host may map it to 8090, but inside Docker use 8080).
DIFY_WEAVIATE_KEY=WVF5YThaHlkYwhGUSmCRgsX3tD5ngdN8pkih
DIFY_WEAVIATE_HOST=http://weaviate
DIFY_WEAVIATE_PORT=8080
DIFY_WEAVIATE_GRPC_PORT=50051

# ── Storage ───────────────────────────────────────────────────────────────────
# Mount your Dify storage volume into the backend container and set this path.
# e.g. if you mount host "D:\llm_dev\dify\docker\volumes\app\storage" → "/dify-storage"
DIFY_STORAGE_PATH=/dify-storage

# Path to PDF storage (Windows Path)
PDF_STORAGE_PATH=./pdf_original

# OCR (Typhoon OCR)
OCR_MODEL=typhoon-ai/typhoon-ocr1.5-2b
OCR_BASE_URL=http://vllm:8000/v1
OCR_API_KEY=no-key
OCR_TARGET_IMAGE_DIM=1500
OCR_FIGURE_LANGUAGE=Thai
OCR_TASK_TYPE=v1.5
OCR_MAX_TOKENS_CAP=8192

# ── Authentication ────────────────────────────────────────────────────────────
USER_ID_HEADER=X-User-Id
JWT_SECRET_KEY=super-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# In development allow the Vite dev server origin.
# Use JSON array format. Keep ["*"] for open dev or restrict as shown below.
CORS_ORIGINS=["*"]
