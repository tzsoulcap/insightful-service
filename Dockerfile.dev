FROM python:3.11-slim

WORKDIR /app

# Install system deps needed by some Python packages
# RUN apt-get update && apt-get install -y --no-install-recommends \
#     gcc \
#     poppler-utils \
#     && rm -rf /var/lib/apt/lists/*
RUN sed -i 's/http:/https:/g' /etc/apt/sources.list.d/debian.sources && \
    apt-get update && \
    apt-get install -y --no-install-recommends gcc poppler-utils && \
    rm -rf /var/lib/apt/lists/*

# Install Python dependencies first (separate layer for caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Source code is mounted at runtime via a bind-mount volume.
# The COPY below is only used when no volume override is present (e.g., plain docker run).
COPY . .

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "app", "--reload-exclude", "*.db", "--reload-exclude", "*.sqlite3", "--reload-exclude", "storage/*"]
